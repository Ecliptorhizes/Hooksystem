{
  "name": "Hooksystem",
  "globIgnorePaths": ["**/.gitkeep"],
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "$path": "src/shared",
      "Packages": {
        "$path": "Packages"
      }
    },
    "ServerStorage": {
      "$className": "ServerStorage",
      "$ignoreUnknownInstances": true,
      "ServerPackages": {
        "$path": "ServerPackages"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "Server": {
        "$path": "src/server"
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "Client": {
          "$path": "src/client"
        }
      },
      "$ignoreUnknownInstances": true
    }
  }
}